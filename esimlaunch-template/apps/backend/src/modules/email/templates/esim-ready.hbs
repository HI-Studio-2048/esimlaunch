<!DOCTYPE html>
<html>
<head><meta charset="UTF-8"><title>Your eSIM is Ready</title></head>
<body style="font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 24px;">
  <h2>Your eSIM is Ready to Install!</h2>
  <p><strong>Plan:</strong> {{planName}}</p>
  <p><strong>ICCID:</strong> {{iccid}}</p>
  <p>Scan the QR code below to install your eSIM:</p>
  {{#if qrCodeUrl}}
  <img src="{{qrCodeUrl}}" alt="eSIM QR Code" style="max-width: 200px;" />
  {{/if}}
  <p><strong>Activation Code:</strong> {{ac}}</p>
  {{#if myEsimsUrl}}
  <p><a href="{{myEsimsUrl}}">View in My eSIMs</a></p>
  {{/if}}
</body>
</html>
