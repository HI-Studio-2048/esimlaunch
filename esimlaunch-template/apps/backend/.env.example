# ============================================================
# Backend environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git.
# ============================================================

# ---------------------------------------------------------------
# Database
# ---------------------------------------------------------------
# PostgreSQL connection string.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/esimlaunch_db

# ---------------------------------------------------------------
# esimlaunch API
# ---------------------------------------------------------------
# Your esimlaunch API base URL (usually https://api.esimlaunch.com)
ESIMLAUNCH_API_BASE=https://api.esimlaunch.com

# Your esimlaunch API key (Bearer token)
ESIMLAUNCH_API_KEY=your_esimlaunch_api_key_here

# ---------------------------------------------------------------
# Dashboard → Site sync (Option A)
# ---------------------------------------------------------------
# When set, the template fetches packages/locations from the main backend
# (esim-connect-hub) instead of calling esimlaunch API directly.
# Merchant markup and branding from the dashboard apply automatically.
# Set ONE of STORE_ID or STORE_SUBDOMAIN. ESIMLAUNCH_HUB_API_URL is required.
#
# ESIMLAUNCH_HUB_API_URL=https://api.esimlaunch.com
# STORE_ID=clxxxxxxxxxxxxx
# STORE_SUBDOMAIN=ezzawanesim

# ---------------------------------------------------------------
# Stripe
# ---------------------------------------------------------------
# Secret key from your Stripe dashboard (sk_test_... for test mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Webhook signing secret from Stripe dashboard (for signature verification)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ---------------------------------------------------------------
# Clerk
# ---------------------------------------------------------------
# Secret key from Clerk dashboard (used for server-side operations)
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Signing secret for Clerk webhooks (from Clerk → Webhooks → your endpoint)
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_signing_secret_here

# ---------------------------------------------------------------
# App URLs
# ---------------------------------------------------------------
# The public URL of your web app (used for Stripe redirect URLs and emails)
WEB_APP_URL=http://localhost:3000

# The public URL of this API (for CORS and docs)
API_BASE_URL=http://localhost:3001

# ---------------------------------------------------------------
# Email (SMTP)
# ---------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM=noreply@yourdomain.com

# ---------------------------------------------------------------
# Security
# ---------------------------------------------------------------
# Secret used to sign guest access tokens. Use a long random string.
GUEST_TOKEN_SECRET=change-this-to-a-long-random-secret

# Optional shared secret for the esimlaunch webhook endpoint
ESIM_WEBHOOK_SECRET=your_esim_webhook_shared_secret

# ---------------------------------------------------------------
# Exchange rates (optional)
# ---------------------------------------------------------------
# API key from exchangerate-api.com for live USD→currency conversion.
# If omitted, falls back to a free public API.
# EXCHANGE_RATE_API_KEY=your_exchangerate_api_key

# ---------------------------------------------------------------
# Server
# ---------------------------------------------------------------
PORT=3001
NODE_ENV=development
