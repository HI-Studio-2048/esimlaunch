# eSIMLaunch backend environment variables.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Core ---
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Postgres. Must start with postgresql:// or postgres://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/esimlaunch

# --- Auth ---
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# --- eSIM Access (upstream provider) ---
ESIM_ACCESS_API_URL=https://api.esimaccess.com
ESIM_ACCESS_ACCESS_CODE=
ESIM_ACCESS_SECRET_KEY=

# --- CORS / frontend ---
CORS_ORIGIN=http://localhost:8080,http://localhost:5173
FRONTEND_URL=http://localhost:5173
MAIN_DOMAIN=esimlaunch.com
ALLOWED_BASE_DOMAIN=esimlaunch.com

# --- Email (Resend) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@esimlaunch.com

# --- Clerk (optional; required only if using Clerk auth) ---
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Subscription plan price IDs (fill in the ones you use)
STRIPE_STARTER_PRICE_ID_MONTHLY=
STRIPE_GROWTH_PRICE_ID_MONTHLY=
STRIPE_SCALE_PRICE_ID_MONTHLY=
STRIPE_TEST_PRICE_ID_MONTHLY=
STRIPE_STARTER_PRICE_ID_YEARLY=
STRIPE_GROWTH_PRICE_ID_YEARLY=
STRIPE_SCALE_PRICE_ID_YEARLY=
STRIPE_TEST_PRICE_ID_YEARLY=

# --- Admin ---
ADMIN_EMAIL=admin@esimlaunch.com

# --- Affiliate program ---
AFFILIATE_COMMISSION_RATE=10      # percent, 0-100
AFFILIATE_MIN_PAYOUT_CENTS=1000   # $10.00 minimum

# --- Optional services ---
REDIS_URL=redis://localhost:6379
EXCHANGE_RATE_API_KEY=

# --- Template ↔ main-backend sync ---
TEMPLATE_ORDER_SYNC_SECRET=
