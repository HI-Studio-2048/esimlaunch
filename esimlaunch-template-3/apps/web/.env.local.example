# ============================================================
# Web app environment variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to git.
# ============================================================

# ---------------------------------------------------------------
# Backend API
# ---------------------------------------------------------------
# The base URL of your backend API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3101/api

# ---------------------------------------------------------------
# Clerk (public keys — safe to expose to the browser)
# ---------------------------------------------------------------
# Publishable key from your Clerk dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# Secret key (server-side only — do NOT prefix with NEXT_PUBLIC_)

# URLs Clerk uses for sign-in/sign-up redirects
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/my-esims
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/my-esims
